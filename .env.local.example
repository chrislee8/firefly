# ── Firefly environment (copy to .env.local and fill in) ──
# All services below run on genuine free tiers — no card required.

# Supabase (https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key — server-only, bypasses RLS for cron ingest/grade writes. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini (https://aistudio.google.com/app/apikey) — free tier
GEMINI_API_KEY=your-gemini-api-key
# Model for grading. Use the rolling `flash-latest` alias — pinned ids like
# gemini-2.0-flash may have a 0 free-tier quota on some projects.
GEMINI_MODEL=gemini-flash-latest

# Shared secret the GitHub Actions cron sends in the x-cron-secret header
# so the /api/cron/* routes reject anything but our scheduled workflow.
CRON_SECRET=generate-a-long-random-string

# ── Analytics (optional) ──
# Google Analytics 4 measurement ID (Admin → Data Streams → Web). Public.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Google Tag Manager container ID (optional; leave blank if unused). Public.
NEXT_PUBLIC_GTM_ID=
